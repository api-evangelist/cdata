    "name": "CData Connect Cloud SQL API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The CData Cloud SQL API is a REST-compatible HTTP endpoint for executing SQL\nqueries, batch operations, and stored procedures across the data sources\nconfigured in a CData Connect Cloud account. Results are returned in JSON.\nAuthentication is OAuth 2.0 / Basic auth for Standard Connect AI, or JWT for\nConnect AI Embed. This best-effort OpenAPI is derived from the public docs at\nhttps://docs.cloud.cdata.com/SQL-API.html and the documentation index at\nhttps://docs.cloud.cdata.com/llms.txt.\n\n\nContact Support:\n Name: CData Software",
      "type": "text/plain"
    }
  }
